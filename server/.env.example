# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

PORT=5000

# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/exptracker

# MongoDB Atlas (replace the line above with your Atlas URI):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/exptracker

# Generate a strong random string for this — it signs all JWTs
JWT_SECRET=replace_this_with_something_strong_and_random
